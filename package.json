{
  "name": "floorplan",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "npm run peggy:generate && vite",
    "build": "npm run peggy:generate && npm run lint && npm run format:check && tsc -b && vite build",
    "ci-build": "npm run peggy:generate && tsc -b && vite build",
    "peggy:generate": "peggy src/floorplan.peggy -o src/floorplan-parser.js --format es",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "preview": "vite preview",
    "test": "node scripts/run-cucumber.js",
    "test:headed": "HEADLESS=false node scripts/run-cucumber.js",
    "test:ci": "CI=true node scripts/run-cucumber.js",
    "test:coverage": "vitest run --coverage",
    "test:project-menu": "node scripts/run-cucumber.js tests/features/project-menu.feature",
    "test:json-editor": "node scripts/run-cucumber.js tests/features/json-editor.feature",
    "test:room-positioning": "node scripts/run-cucumber.js tests/features/room-positioning.feature",
    "test:architectural": "node scripts/run-cucumber.js tests/features/architectural-elements.feature",
    "test:svg-rendering": "node scripts/run-cucumber.js tests/features/svg-rendering.feature",
    "test:error-handling": "node scripts/run-cucumber.js tests/features/error-handling.feature",
    "test:dsl-editor": "node scripts/run-cucumber.js tests/features/dsl-editor.feature",
    "test:room-resizing": "node scripts/run-cucumber.js tests/features/room-resizing.feature",
    "test:room-resizing:headed": "HEADLESS=false node scripts/run-cucumber.js tests/features/room-resizing.feature",
    "test:object-resizing": "node scripts/run-cucumber.js tests/features/object-resizing.feature",
    "test:object-resizing:headed": "HEADLESS=false node scripts/run-cucumber.js tests/features/object-resizing.feature",
    "validate": "npm run lint && npm run format:check && npm run test"
  },
  "dependencies": {
    "@codemirror/language": "^6.12.4",
    "@codemirror/view": "^6.43.4",
    "@lezer/highlight": "^1.2.3",
    "@uiw/codemirror-theme-vscode": "^4.25.10",
    "@uiw/react-codemirror": "^4.25.10",
    "react": "^19.1.1",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@cucumber/cucumber": "^13.0.0",
    "@playwright/test": "^1.61.1",
    "@types/node": "^25.0.10",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.9",
    "jsdom": "^29.1.1",
    "oxlint": "^1.74.0",
    "peggy": "^5.0.6",
    "prettier": "^3.9.5",
    "tsx": "^4.23.1",
    "typescript": "~7.0.2",
    "vite": "^8.1.4",
    "vitest": "^4.1.9",
    "wait-on": "^9.0.10"
  }
}
